# =============================================
# CyberRAG-IDS Backend — Environment Template
# Copy to .env and fill in values.
# NEVER commit .env to Git.
# =============================================

# ── Application ───────────────────────────────
APP_NAME=CyberRAG-IDS
APP_VERSION=1.0.0
DEBUG=false
LOG_LEVEL=INFO

# ── Server ────────────────────────────────────
HOST=0.0.0.0
PORT=8000
# Comma-separated list of allowed frontend origins:
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── Ollama (local — no API key needed) ────────
OLLAMA_BASE_URL=http://localhost:11434
# Options: llama3.2  |  mistral-nemo  |  llama3.1
OLLAMA_LLM_MODEL=llama3.2
# Must be pulled: ollama pull nomic-embed-text
OLLAMA_EMBED_MODEL=nomic-embed-text

# ── RAG / ChromaDB ────────────────────────────
CHROMA_DB_PATH=./rag/chroma_db
KNOWLEDGE_BASE_PATH=./rag/knowledge_base
RAG_CHUNK_SIZE=1000
RAG_CHUNK_OVERLAP=200
# Number of chunks retrieved per query:
RAG_TOP_K=5

# ── ML / LSTM ─────────────────────────────────
MODEL_CHECKPOINT_PATH=./ml/checkpoints/lstm_ids.pt
MODEL_SCALER_PATH=./ml/checkpoints/scaler.pkl
# Probability threshold: flows above this are flagged as attacks
ANOMALY_THRESHOLD=0.5

# ── Rate Limiting ─────────────────────────────
RATE_LIMIT_PER_MINUTE=60

# ── Reports ───────────────────────────────────
REPORTS_PATH=./reports
